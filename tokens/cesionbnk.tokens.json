{
  "$schema": "https://json.schemastore.org/style-dictionary.json",
  "$metadata": {
    "name": "CESIONBNK Design Tokens",
    "version": "7.0.1",
    "description": "Single source of truth for CESIONBNK brand tokens. Used by: Figma Variables, CSS custom properties, Tailwind config.",
    "updatedAt": "2026-03-16",
    "changelog": "v7.0.1: Standardized foreground colors to professional gray (#3f3f46) instead of harsh black (#222222)"
  },

  "color": {
    "brand": {
      "primary": {
        "$value": { "light": "#374151", "dark": "#d1d5db" },
        "$type": "color",
        "$description": "Main CTA color. Gray-700 light / Gray-300 dark."
      },
      "primary-fg": {
        "$value": { "light": "#ffffff", "dark": "#09090b" },
        "$type": "color",
        "$description": "Text on top of primary backgrounds."
      },
      "secondary": {
        "$value": { "light": "#796eff", "dark": "#796eff" },
        "$type": "color",
        "$description": "Accent / brand violet. Same in both modes."
      },
      "secondary-fg": {
        "$value": { "light": "#ffffff", "dark": "#09090b" },
        "$type": "color"
      },
      "ring": {
        "$value": { "light": "#374151", "dark": "#d1d5db" },
        "$type": "color",
        "$description": "Focus ring color. Matches primary."
      }
    },

    "semantic": {
      "destructive": {
        "$value": { "light": "#ef4444", "dark": "#ef4444" },
        "$type": "color"
      },
      "destructive-fg": {
        "$value": { "light": "#ffffff", "dark": "#fafafa" },
        "$type": "color"
      },
      "success": {
        "$value": { "light": "#22c55e", "dark": "#22c55e" },
        "$type": "color"
      },
      "success-fg": {
        "$value": { "light": "#ffffff", "dark": "#052e16" },
        "$type": "color"
      },
      "warning": {
        "$value": { "light": "#f59e0b", "dark": "#f59e0b" },
        "$type": "color"
      },
      "warning-fg": {
        "$value": { "light": "#ffffff", "dark": "#1c1917" },
        "$type": "color"
      },
      "info": {
        "$value": { "light": "#3b82f6", "dark": "#3b82f6" },
        "$type": "color"
      },
      "info-fg": {
        "$value": { "light": "#ffffff", "dark": "#172554" },
        "$type": "color"
      },

      "success-subtle": {
        "$value": { "light": "#f0fdf4", "dark": "#052e16" },
        "$type": "color",
        "$description": "Soft success background. Used for status badges, row highlights."
      },
      "destructive-subtle": {
        "$value": { "light": "#fef2f2", "dark": "#450a0a" },
        "$type": "color",
        "$description": "Soft destructive background. Used for error badges, alert fills."
      },
      "warning-subtle": {
        "$value": { "light": "#fef3c7", "dark": "#451a03" },
        "$type": "color",
        "$description": "Soft warning background. Used for caution badges, info banners."
      },
      "info-subtle": {
        "$value": { "light": "#eff6ff", "dark": "#172554" },
        "$type": "color",
        "$description": "Soft info background. Used for informational badges and boxes."
      },
      "secondary-subtle": {
        "$value": { "light": "#ede9fe", "dark": "#2e1065" },
        "$type": "color",
        "$description": "Soft secondary/violet background. Used for accent badges."
      },

      "success-on-subtle": {
        "$value": { "light": "#15803d", "dark": "#4ade80" },
        "$type": "color",
        "$description": "Text/icon color on success-subtle backgrounds."
      },
      "destructive-on-subtle": {
        "$value": { "light": "#b91c1c", "dark": "#f87171" },
        "$type": "color",
        "$description": "Text/icon color on destructive-subtle backgrounds."
      },
      "warning-on-subtle": {
        "$value": { "light": "#b45309", "dark": "#fbbf24" },
        "$type": "color",
        "$description": "Text/icon color on warning-subtle backgrounds."
      },
      "caution": {
        "$value": { "light": "#f97316", "dark": "#f97316" },
        "$type": "color",
        "$description": "Orange — riesgo alto, between warning and destructive."
      },
      "caution-foreground": {
        "$value": { "light": "#ffffff", "dark": "#1c1917" },
        "$type": "color"
      },
      "caution-subtle": {
        "$value": { "light": "#fff7ed", "dark": "#431407" },
        "$type": "color",
        "$description": "Soft caution background."
      },
      "caution-on-subtle": {
        "$value": { "light": "#c2410c", "dark": "#fb923c" },
        "$type": "color",
        "$description": "Text/icon color on caution-subtle backgrounds."
      },
      "info-on-subtle": {
        "$value": { "light": "#1d4ed8", "dark": "#93c5fd" },
        "$type": "color",
        "$description": "Text/icon color on info-subtle backgrounds."
      },
      "secondary-on-subtle": {
        "$value": { "light": "#7c3aed", "dark": "#c4b5fd" },
        "$type": "color",
        "$description": "Text/icon color on secondary-subtle backgrounds."
      }
    },

    "ui": {
      "switch-bg": {
        "$value": { "light": "#cbced4", "dark": "#475569" },
        "$type": "color",
        "$description": "Switch unchecked track background."
      },
      "input-bg": {
        "$value": { "light": "#ffffff", "dark": "#334155" },
        "$type": "color",
        "$description": "Input field background."
      }
    },

    "surface": {
      "background": {
        "$value": { "light": "#ffffff", "dark": "#09090b" },
        "$type": "color"
      },
      "foreground": {
        "$value": { "light": "#3f3f46", "dark": "#fafafa" },
        "$type": "color",
        "$description": "Primary foreground text color. Professional gray in light mode for enhanced readability."
      },
      "card": {
        "$value": { "light": "#ffffff", "dark": "#09090b" },
        "$type": "color"
      },
      "card-fg": {
        "$value": { "light": "#3f3f46", "dark": "#fafafa" },
        "$type": "color",
        "$description": "Text color on card surfaces. Matches professional gray standard."
      },
      "popover": {
        "$value": { "light": "#ffffff", "dark": "#18181b" },
        "$type": "color"
      },
      "popover-fg": {
        "$value": { "light": "#3f3f46", "dark": "#fafafa" },
        "$type": "color",
        "$description": "Text color on popover surfaces. Matches professional gray standard."
      },
      "muted": {
        "$value": { "light": "#f4f4f5", "dark": "#27272a" },
        "$type": "color"
      },
      "muted-fg": {
        "$value": { "light": "#52525b", "dark": "#a1a1aa" },
        "$type": "color"
      },
      "accent": {
        "$value": { "light": "#f4f4f5", "dark": "#27272a" },
        "$type": "color"
      },
      "border": {
        "$value": { "light": "#e4e4e7", "dark": "#27272a" },
        "$type": "color"
      },
      "input": {
        "$value": { "light": "#e4e4e7", "dark": "#27272a" },
        "$type": "color"
      }
    }
  },

  "radius": {
    "sm":      { "$value": 6,    "$type": "dimension", "$description": "0.375rem" },
    "default": { "$value": 10,   "$type": "dimension", "$description": "0.625rem — all components default" },
    "lg":      { "$value": 12,   "$type": "dimension", "$description": "0.75rem" },
    "xl":      { "$value": 16,   "$type": "dimension", "$description": "1rem" },
    "2xl":     { "$value": 24,   "$type": "dimension", "$description": "1.5rem" },
    "full":    { "$value": 9999, "$type": "dimension", "$description": "Pill shape" }
  },

  "spacing": {
    "1":  { "$value": 4,  "$type": "dimension" },
    "2":  { "$value": 8,  "$type": "dimension" },
    "3":  { "$value": 12, "$type": "dimension" },
    "4":  { "$value": 16, "$type": "dimension" },
    "5":  { "$value": 20, "$type": "dimension" },
    "6":  { "$value": 24, "$type": "dimension" },
    "8":  { "$value": 32, "$type": "dimension" },
    "10": { "$value": 40, "$type": "dimension" },
    "12": { "$value": 48, "$type": "dimension" },
    "16": { "$value": 64, "$type": "dimension" }
  },

  "typography": {
    "fontFamily": {
      "sans": { "$value": "Inter, 'Gotham HTF', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', 'Fira Code', monospace",   "$type": "fontFamily" }
    },
    "fontSize": {
      "2xs":  { "$value": 10, "$type": "dimension", "$description": "Tight UI contexts: avatars, inline badges, nav counters" },
      "xs":   { "$value": 12, "$type": "dimension" },
      "sm":   { "$value": 14, "$type": "dimension" },
      "base": { "$value": 16, "$type": "dimension" },
      "lg":   { "$value": 18, "$type": "dimension" },
      "xl":   { "$value": 20, "$type": "dimension" },
      "2xl":  { "$value": 24, "$type": "dimension" },
      "3xl":  { "$value": 32, "$type": "dimension" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.25, "$type": "number" },
      "normal": { "$value": 1.5,  "$type": "number" },
      "relaxed":{ "$value": 1.75, "$type": "number" }
    },
    "fontWeight": {
      "regular": { "$value": 400, "$type": "number" },
      "medium":  { "$value": 500, "$type": "number" },
      "semibold":{ "$value": 600, "$type": "number" },
      "bold":    { "$value": 700, "$type": "number" }
    }
  },

  "shadow": {
    "elevation-1": { "$value": "0 1px 2px rgba(0,0,0,0.05)",                     "$type": "shadow" },
    "elevation-2": { "$value": "0 4px 6px rgba(0,0,0,0.10)",                     "$type": "shadow" },
    "elevation-3": { "$value": "0 10px 15px rgba(0,0,0,0.10)",                   "$type": "shadow" },
    "elevation-4": { "$value": "0 20px 25px rgba(0,0,0,0.10), 0 8px 10px rgba(0,0,0,0.04)", "$type": "shadow" }
  }
}
